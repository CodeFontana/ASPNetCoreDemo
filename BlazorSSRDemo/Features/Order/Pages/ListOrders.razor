@page "/orders"
@attribute [StreamRendering]
@inject IFoodOrderRepository orderData
@inject NavigationManager navMan

<PageTitle>Orders - Blazor SSR</PageTitle>

<h1>Orders</h1>

@if (_orders is null)
{
    <h4>Loading orders...</h4>
}
else if (_orders.Any() == false)
{
    <p>No orders have been placed yet.</p>
    <a href="order/create" class="btn btn-primary">Place Order</a>
}
else
{
    <table class="table table-striped table-sm align-middle" style="font-size: 0.9rem;">
        <thead class="thead-dark">
            <tr>
                <th>Order Name</th>
                <th>Meal</th>
                <th class="text-center">Qty</th>
                <th class="text-end">Total</th>
                <th>Date</th>
                <th style="width: 120px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (FoodOrderSummaryModel order in _orders)
            {
                <tr>
                    <td>@order.OrderName</td>
                    <td>@order.FoodTitle</td>
                    <td class="text-center">@order.Quantity</td>
                    <td class="text-end">@string.Format("{0:C}", order.Total)</td>
                    <td>@order.OrderDate.ToString("g")</td>
                    <td class="text-nowrap">
                        <a href="order/display/@order.Id" class="btn btn-outline-primary btn-sm">View</a>
                        <EditForm Enhance FormName="@($"delete-order-{order.Id}")" Model="order"
                                  OnSubmit="() => DeleteOrderAsync(order.Id)" class="d-inline">
                            <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                        </EditForm>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a href="order/create" class="btn btn-primary">Place Order</a>
}

@code {
    private IEnumerable<FoodOrderSummaryModel>? _orders;

    protected override async Task OnInitializedAsync()
    {
        _orders = await orderData.GetAllOrdersAsync();
    }

    private async Task DeleteOrderAsync(int id)
    {
        await orderData.DeleteOrderAsync(id);
        navMan.NavigateTo("orders", forceLoad: true);
    }
}
