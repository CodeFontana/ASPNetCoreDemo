@model IEnumerable<FoodModel>

@{
    ViewData["Title"] = "Menu";
}

<h1>Menu</h1>

<table class="table table-striped table-sm align-middle" style="font-size: 0.9rem;">
    <thead class="thead-dark">
        <tr>
            <th>Item</th>
            <th>Description</th>
            <th class="text-end">Price</th>
            <th style="width: 120px;"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Title)</td>
                <td>@Html.DisplayFor(modelItem => item.Description)</td>
                <td class="text-end">@string.Format("{0:C}", item.Price)</td>
                <td class="text-nowrap">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Edit</a>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-controller="Orders" asp-action="Create" class="btn btn-primary me-2">Place Order</a>
<a asp-action="Create" class="btn btn-outline-success">Add Menu Item</a>
