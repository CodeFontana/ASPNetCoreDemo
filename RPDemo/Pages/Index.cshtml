@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="app-hero py-5">
    <div class="d-inline-flex align-items-center gap-2 mb-3 app-eyebrow">
        <i class="bi bi-stars"></i>
        <span class="text-uppercase small fw-semibold">ASP.NET Core Razor Pages &mdash; Demo</span>
    </div>
    <h1 class="display-5 fw-bold mb-3">Hello, world.</h1>
    <p class="lead text-secondary mb-4 app-lead">
        A modernized ASP.NET Core Razor Pages demo on plain Bootstrap 5.3, with
        Inter and JetBrains Mono typography, a 3-state Light / Dark / Auto
        theme picker, and a navbar that flows through Bootstrap's CSS variables.
    </p>
    <div class="d-flex flex-wrap gap-2">
        <a asp-page="/Food/List" class="btn btn-primary">
            <i class="bi bi-card-list pe-1"></i> Browse the menu
        </a>
        <a asp-page="/Orders/List" class="btn btn-outline-secondary">
            <i class="bi bi-receipt pe-1"></i> View orders
        </a>
    </div>
</div>

<div class="row g-3 g-md-4 mb-5">
    <div class="col-md-4">
        <div class="card h-100 app-feature-card">
            <div class="card-body">
                <div class="app-feature-icon mb-3">
                    <i class="bi bi-file-earmark-code-fill"></i>
                </div>
                <h5 class="card-title">Pages, not controllers</h5>
                <p class="card-text text-secondary mb-0">
                    Razor Pages co-locate routing, page model, and markup &mdash;
                    less ceremony than MVC, with the same tag helpers, model
                    binding, and validation.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 app-feature-card">
            <div class="card-body">
                <div class="app-feature-icon mb-3">
                    <i class="bi bi-palette-fill"></i>
                </div>
                <h5 class="card-title">Theme-aware chrome</h5>
                <p class="card-text text-secondary mb-0">
                    Navbar, cards, and form controls all key off Bootstrap 5.3's
                    <code>data-bs-theme</code> tokens, so flipping between Light, Dark,
                    and Auto restyles the whole app instantly.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 app-feature-card">
            <div class="card-body">
                <div class="app-feature-icon mb-3">
                    <i class="bi bi-rocket-takeoff-fill"></i>
                </div>
                <h5 class="card-title">Ready to grow</h5>
                <p class="card-text text-secondary mb-0">
                    A clean foundation with Bootstrap 5.3, an external theme-picker
                    script that runs before paint to avoid FOUC, and tag-helper-driven
                    navigation &mdash; ready to evolve into a real Razor Pages app.
                </p>
            </div>
        </div>
    </div>
</div>
