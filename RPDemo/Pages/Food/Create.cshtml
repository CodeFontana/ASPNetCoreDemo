@page
@model RPDemo.Pages.Food.CreateModel
@{
    ViewData["Title"] = "Add Menu Item";
}

<h1>Add Menu Item</h1>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-2">
                <label asp-for="Food.Title" class="control-label"></label>
                <input asp-for="Food.Title" class="form-control form-control-sm" />
                <span asp-validation-for="Food.Title" class="text-danger"></span>
            </div>
            <div class="form-group mb-2">
                <label asp-for="Food.Description" class="control-label"></label>
                <input asp-for="Food.Description" class="form-control form-control-sm" />
                <span asp-validation-for="Food.Description" class="text-danger"></span>
            </div>
            <div class="form-group mb-2" style="max-width: 150px;">
                <label asp-for="Food.Price" class="control-label"></label>
                <input asp-for="Food.Price" class="form-control form-control-sm" />
                <span asp-validation-for="Food.Price" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Add Item" class="btn btn-success btn-sm" />
                <a asp-page="./List" class="btn btn-secondary btn-sm">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
