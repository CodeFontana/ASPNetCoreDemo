@{
    string? currentPage = ViewContext.RouteData.Values["page"]?.ToString();

    string NavClass(string page, bool prefix = false)
    {
        bool isActive = string.Equals(currentPage, page, StringComparison.OrdinalIgnoreCase)
            || (prefix && currentPage is not null && currentPage.StartsWith(page + "/", StringComparison.OrdinalIgnoreCase));
        return isActive ? "nav-link active" : "nav-link";
    }

    string homeNavClass = NavClass("/Index");
    string menuNavClass = NavClass("/Food", prefix: true);
    string ordersNavClass = NavClass("/Orders/List");
    string createOrderNavClass = NavClass("/Orders/Create");

    RPDemo.Models.ThemePickerModel themePickerModel = new() { Class = "me-2" };
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <title>@ViewData["Title"] - RPDemo</title>

    @* Apply the saved theme synchronously, before paint, to avoid FOUC. *@
    <script src="~/js/theme-picker.js" asp-append-version="true"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@@300;400;500;600;700;800&family=JetBrains+Mono:wght@@400;500;600&display=swap" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.8/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RPDemo.styles.css" asp-append-version="true" />
</head>
<body class="app-shell">
    <header>
        <nav class="navbar navbar-expand-md fixed-top app-navbar shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center gap-2 fw-semibold" asp-page="/Index">
                    <i class="bi bi-bricks fs-4 text-primary"></i>
                    <span>RPDemo</span>
                </a>

                <div class="d-flex align-items-center order-md-last">
                    <partial name="_ThemePicker" model="themePickerModel" />
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
                            aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>

                <div id="navbarSupportedContent" class="collapse navbar-collapse">
                    <ul class="navbar-nav me-auto mb-0">
                        <li class="nav-item">
                            <a class="@homeNavClass" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="@menuNavClass" asp-page="/Food/List">Menu</a>
                        </li>
                        <li class="nav-item">
                            <a class="@ordersNavClass" asp-page="/Orders/List">Orders</a>
                        </li>
                        <li class="nav-item">
                            <a class="@createOrderNavClass" asp-page="/Orders/Create">Create Order</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="container" style="padding-top: 4.5rem;">
        @RenderBody()
    </main>

    <footer class="app-footer mt-5">
        <div class="container d-flex flex-wrap justify-content-between align-items-center gap-2">
            <span>&copy; @DateTime.Now.Year &middot; RPDemo</span>
            <a class="text-decoration-none" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
