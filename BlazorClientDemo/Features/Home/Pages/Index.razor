@page "/"

<PageTitle>Home - Blazor Client</PageTitle>

<div class="home-hero py-5">
    <div class="d-inline-flex align-items-center gap-2 mb-3 home-eyebrow">
        <i class="bi bi-stars"></i>
        <span class="text-uppercase small fw-semibold">Blazor WebAssembly &mdash; Demo</span>
    </div>
    <h1 class="display-5 fw-bold mb-3">Hello, world.</h1>
    <p class="lead text-secondary mb-4 home-lead">
        A modernized Blazor WebAssembly demo on plain Bootstrap 5.3, with Inter
        and JetBrains Mono typography, a 3-state Light / Dark / Auto theme picker,
        and a navbar that flows through Bootstrap's CSS variables.
    </p>
    <div class="d-flex flex-wrap gap-2">
        <a href="food" class="btn btn-primary">
            <i class="bi bi-card-list pe-1"></i> Browse the menu
        </a>
        <a href="orders" class="btn btn-outline-secondary">
            <i class="bi bi-receipt pe-1"></i> View orders
        </a>
    </div>
</div>

<div class="row g-3 g-md-4 mb-5">
    <div class="col-md-4">
        <div class="card h-100 home-feature-card">
            <div class="card-body">
                <div class="home-feature-icon mb-3">
                    <i class="bi bi-cpu-fill"></i>
                </div>
                <h5 class="card-title">Runs in the browser</h5>
                <p class="card-text text-secondary mb-0">
                    Blazor WebAssembly downloads the .NET runtime and your assemblies
                    once, then renders C# components directly on the client &mdash; no
                    server round-trips for UI updates.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 home-feature-card">
            <div class="card-body">
                <div class="home-feature-icon mb-3">
                    <i class="bi bi-palette-fill"></i>
                </div>
                <h5 class="card-title">Theme-aware chrome</h5>
                <p class="card-text text-secondary mb-0">
                    Navbar, cards, and form controls all key off Bootstrap 5.3's
                    <code>data-bs-theme</code> tokens, so flipping between Light, Dark,
                    and Auto restyles the whole app instantly.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 home-feature-card">
            <div class="card-body">
                <div class="home-feature-icon mb-3">
                    <i class="bi bi-rocket-takeoff-fill"></i>
                </div>
                <h5 class="card-title">Ready to grow</h5>
                <p class="card-text text-secondary mb-0">
                    A clean foundation with feature-folder routing, scoped CSS, and a
                    no-flash theme bootstrap script &mdash; ready to evolve into a
                    real client-side app.
                </p>
            </div>
        </div>
    </div>
</div>
