@page "/food"
@inject HttpClient Http
@inject NavigationManager navMan

<PageTitle>Menu - Blazor Client</PageTitle>

<h1>Menu</h1>

@if (string.IsNullOrWhiteSpace(_errorString) == false)
{
    <h4>System Error</h4>
    <p>@_errorString</p>
}
else if (_foodList is null)
{
    <h4>Loading menu...</h4>
}
else
{
    <table class="table table-striped table-sm align-middle" style="font-size: 0.9rem;">
        <thead class="thead-dark">
            <tr>
                <th>Item</th>
                <th>Description</th>
                <th class="text-end">Price</th>
                <th style="width: 120px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (FoodModel food in _foodList)
            {
                <tr>
                    <td>@food.Title</td>
                    <td>@food.Description</td>
                    <td class="text-end">@string.Format("{0:C}", food.Price)</td>
                    <td class="text-nowrap">
                        <a href="food/edit/@food.Id" class="btn btn-outline-primary btn-sm">Edit</a>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteItemAsync(food.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a href="order/create" class="btn btn-primary me-2">Place Order</a>
    <a href="food/create" class="btn btn-outline-success">Add Menu Item</a>
}

@code {
    private List<FoodModel>? _foodList;
    private string? _errorString;

    protected override async Task OnInitializedAsync()
    {
        await LoadFoodAsync();
    }

    private async Task LoadFoodAsync()
    {
        try
        {
            HttpResponseMessage response = await Http.GetAsync("api/food");
            if (response.IsSuccessStatusCode)
            {
                _foodList = await response.Content.ReadFromJsonAsync<List<FoodModel>>();
            }
            else
            {
                _errorString = response.ReasonPhrase;
            }
        }
        catch (Exception ex)
        {
            _errorString = ex.Message;
        }
    }

    private async Task DeleteItemAsync(int id)
    {
        await Http.DeleteAsync($"api/food/{id}");
        await LoadFoodAsync();
    }
}
