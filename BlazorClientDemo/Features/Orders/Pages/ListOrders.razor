@page "/orders"
@inject HttpClient Http
@inject NavigationManager navMan

<PageTitle>Orders - Blazor Client</PageTitle>

<h1>Orders</h1>

@if (string.IsNullOrWhiteSpace(_errorString) == false)
{
    <h4>System Error</h4>
    <p>@_errorString</p>
}
else if (_orders is null)
{
    <h4>Loading orders...</h4>
}
else if (_orders.Count == 0)
{
    <p>No orders have been placed yet.</p>
    <a href="order/create" class="btn btn-primary">Place Order</a>
}
else
{
    <table class="table table-striped table-sm align-middle" style="font-size: 0.9rem;">
        <thead class="thead-dark">
            <tr>
                <th>Order Name</th>
                <th>Meal</th>
                <th class="text-center">Qty</th>
                <th class="text-end">Total</th>
                <th>Date</th>
                <th style="width: 120px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (FoodOrderSummaryModel order in _orders)
            {
                <tr>
                    <td>@order.OrderName</td>
                    <td>@order.FoodTitle</td>
                    <td class="text-center">@order.Quantity</td>
                    <td class="text-end">@string.Format("{0:C}", order.Total)</td>
                    <td>@order.OrderDate.ToString("g")</td>
                    <td class="text-nowrap">
                        <a href="order/display/@order.Id" class="btn btn-outline-primary btn-sm">View</a>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteOrderAsync(order.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a href="order/create" class="btn btn-primary">Place Order</a>
}

@code {
    private List<FoodOrderSummaryModel>? _orders;
    private string? _errorString;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrdersAsync();
    }

    private async Task LoadOrdersAsync()
    {
        try
        {
            HttpResponseMessage response = await Http.GetAsync("api/order");
            if (response.IsSuccessStatusCode)
            {
                _orders = await response.Content.ReadFromJsonAsync<List<FoodOrderSummaryModel>>();
            }
            else
            {
                _errorString = response.ReasonPhrase;
            }
        }
        catch (Exception ex)
        {
            _errorString = ex.Message;
        }
    }

    private async Task DeleteOrderAsync(int id)
    {
        await Http.DeleteAsync($"api/order/{id}");
        await LoadOrdersAsync();
    }
}
